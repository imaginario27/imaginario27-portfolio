{
    "name": "imaginario27-portfolio",
    "type": "module",
    "private": true,
    "scripts": {
        "build": "nuxt build",
        "dev": "nuxt dev",
        "generate": "nuxt generate",
        "preview": "nuxt preview",
        "postinstall": "nuxt prepare",
        "generate-theme": "ts-node app/scripts/generate-theme.ts",
        "update-theme-colors": "ts-node app/scripts/update-ui-theme-colors.ts",
        "update-design-system": "npm i @imaginario27/air-ui-ds@latest @imaginario27/air-ui-utils@latest",
        "test": "vitest run",
        "test:watch": "vitest",
        "sync-translations": "ts-node app/scripts/sync-translations.ts",
        "sync-translations:migrate": "ts-node app/scripts/sync-translations.ts --migrate",
        "apply-translations": "ts-node app/scripts/apply-translations.ts",
        "translations:check": "ts-node app/scripts/check-translations.ts",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "sonar": "sonar-scanner",
        "sonar:check": "ts-node app/scripts/sonar-check.ts",
        "preflight-check": "npm run format:check && npm run test && npm run translations:check"
    },
    "dependencies": {
        "@imaginario27/air-ui-ds": "1.9.4",
        "@imaginario27/air-ui-utils": "1.2.1",
        "@nuxt/content": "3.12.0",
        "@nuxt/image": "2.0.0",
        "@nuxtjs/i18n": "10.2.4",
        "@pinia/nuxt": "0.11.3",
        "@tailwindcss/vite": "4.2.2",
        "@vueuse/core": "14.2.1",
        "@vueuse/motion": "3.0.3",
        "@vueuse/nuxt": "14.2.1",
        "better-sqlite3": "12.8.0",
        "nuxt": "4.4.2",
        "nuxt-graphql-client": "0.2.46",
        "pinia": "3.0.4",
        "tailwindcss": "4.2.2",
        "three": "0.184.0",
        "vue": "^3.5.31",
        "vue-router": "^5.0.4",
        "vue3-toastify": "0.2.9"
    },
    "devDependencies": {
        "@nuxt/test-utils": "4.0.3",
        "@vitest/coverage-v8": "4.1.2",
        "@vue/test-utils": "2.4.6",
        "eslint": "10.2.0",
        "happy-dom": "20.8.9",
        "playwright-core": "1.59.1",
        "prettier": "3.8.1",
        "sonarqube-scanner": "4.3.6",
        "ts-node": "10.9.2",
        "typescript": "6.0.2",
        "vitest": "4.1.2"
    }
}
